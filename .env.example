# OpenRouter (Primary - Get key at https://openrouter.ai/settings/keys)
OPENROUTER_API_KEY=

# Ollama Local (Install from https://ollama.com, run: ollama serve)
# No API key needed - just ensure Ollama is running locally
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Groq (Optional - Get key at https://console.groq.com/api-keys)
GROQ_API_KEY=

# Gemini (Optional - Get key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# OpenAI (Optional - Paid - Get key at https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# App Configuration
FLASK_SECRET_KEY=change-this-secret-key-in-production
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=qwen2.5-coder:7b
PORT=5000